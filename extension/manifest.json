{
  "manifest_version": 3,
  "name": "ChromeMilk",
  "version": "1.0.0",
  "description": "Turn any webpage into structured, searchable knowledge in one click.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["http://localhost:3456/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ChromeMilk — Extract Knowledge"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
